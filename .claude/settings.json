{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(cat *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(pnpm install)",
      "Bash(pnpm turbo *)",
      "Bash(pnpm biome *)",
      "Bash(pnpm vitest *)",
      "Bash(pnpm markdownlint-cli2 *)",
      "Bash(pnpm markdown-link-check *)",
      "Bash(cargo check *)",
      "Bash(cargo clippy *)",
      "Bash(cargo fmt *)",
      "Bash(cargo deny *)",
      "Bash(cargo test *)",
      "Bash(cargo audit *)",
      "Bash(docker compose *)",
      "Bash(docker ps)",
      "Bash(docker logs *)",
      "Bash(rustc --version)",
      "Bash(cargo --version)",
      "Bash(node --version)",
      "Bash(pnpm --version)",
      "Bash(.venv/Scripts/pip install:*)",
      "Bash(.venv/Scripts/scrapling:*)",
      "Bash(git push origin main)",
      "Bash(git push origin *)",
      "Bash(git fetch *)",
      "Bash(git pull *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(psql * DROP *)",
      "Bash(curl * | sh)",
      "Bash(wget * | bash)",
      "Bash(* > /etc/*)",
      "Bash(sudo *)"
    ]
  },
  "hooks": {}
}
