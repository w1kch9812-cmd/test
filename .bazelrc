common --enable_bzlmod
common --announce_rc
# Bazel's Bzlmod lockfile is intentionally disabled for now because the generated
# MODULE.bazel.lock exceeds this repo's 1500-line file limit. Re-enable only with
# an ADR-approved partition/exception strategy.
common --lockfile_mode=off

# Optional local/CI remote-cache credentials live outside version control. Copy
# `.bazelrc.remote.example` to `.bazelrc.remote` and fill provider-specific
# values when a managed cache is approved.
try-import %workspace%/.bazelrc.remote

# Local cache is the default developer baseline. Managed remote cache/execution
# is introduced only after credentials, ownership, and cache-write policy exist.
build --disk_cache=~/.cache/bazel/gongzzang/disk
build --repository_cache=~/.cache/bazel/gongzzang/repository
build --guard_against_concurrent_changes

test --test_output=errors
test --test_summary=detailed
test --test_env=CI
test --test_env=SQLX_OFFLINE
test --test_env=RUST_BACKTRACE=1
test --test_env=DATABASE_URL
test --test_env=POSTGRES_USER
test --test_env=POSTGRES_PASSWORD
test --test_env=POSTGRES_DB
test --test_env=NEXT_PUBLIC_API_BASE_URL
test --test_env=NEXT_PUBLIC_NAVER_MAPS_CLIENT_ID
test --test_env=NEXT_PUBLIC_PLATFORM_CORE_BASE_URL
test --test_env=ZITADEL_ISSUER
test --test_env=ZITADEL_CLIENT_ID
test --test_env=ZITADEL_AUDIENCE
test --test_env=ZITADEL_REDIRECT_URI
test --test_env=REDIS_URL
test --test_env=SESSION_SECRET
test --test_env=INTERNAL_AUTH_SECRET
test --test_env=PLATFORM_CORE_WEBHOOK_SECRET
test --test_env=PLAYWRIGHT_BROWSERS_PATH

build:dev --remote_download_toplevel

build:ci --remote_download_minimal
build:ci --noshow_progress
test:ci --test_output=errors
test:ci --test_summary=detailed
