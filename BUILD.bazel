            "tests/**/*.jsonc",
            "tests/**/*.mjs",
            "tests/**/*.ts",
            "tools/**/*.cjs",
            "tools/**/*.js",
            "tools/**/*.json",
            "tools/**/*.jsonc",
            "tools/**/*.mjs",
            "tools/**/*.ts",
        ],
        exclude = [
            "**/.next/**",
            "**/.turbo/**",
            "**/_archive/**",
            "**/coverage/**",
            "**/dist/**",
            "**/node_modules/**",
            "**/playwright-report/**",
            "**/reference/**",
            "**/target/**",
            "**/test-results/**",
        ],
        allow_empty = True,
    ) + [
        ".gitignore",
        ".markdownlint-cli2.jsonc",
        ".markdownlint.json",
        ".mcp.json",
        "biome.json",
        "package.json",
        "renovate.json",
        "tsconfig.base.json",
        "turbo.json",
    ],
)

