load("@aspect_rules_ts//ts:defs.bzl", "ts_config", "ts_project")
load("@npm//:defs.bzl", "npm_link_all_packages")

package(default_visibility = ["//visibility:public"])

npm_link_all_packages(name = "node_modules")

filegroup(
    name = "bazel_control_plane",
    srcs = [
        ".bazelignore",
        ".bazelrc",
        ".bazelversion",
        ".npmrc",
        ".nvmrc",
        "MODULE.bazel",
        "package.json",
        "pnpm-lock.yaml",
