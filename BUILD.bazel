            "infrastructure/**/*.json",
            "infrastructure/**/*.jsonc",
            "infrastructure/**/*.mjs",
            "infrastructure/**/*.ts",
            "packages/**/*.cjs",
            "packages/**/*.css",
            "packages/**/*.js",
            "packages/**/*.json",
            "packages/**/*.jsonc",
            "packages/**/*.jsx",
            "packages/**/*.mjs",
            "packages/**/*.ts",
            "packages/**/*.tsx",
            "scripts/**/*.cjs",
