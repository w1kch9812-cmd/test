  "forbidden_unowned_root_prefix_writes": ["bronze/", "silver/", "gold/"],
  "required_env_contract": {
    "GONGZZANG_LAKEHOUSE_R2_BUCKET": "gongzzang-lakehouse-prod",
    "LISTING_PHOTO_R2_BUCKET": "gongzzang-lakehouse-prod"
