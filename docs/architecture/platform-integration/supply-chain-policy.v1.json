{
  "schema_version": "gongzzang.platform_integration.supply_chain_policy.v1",
  "repo_slug": "gongzzang",
  "owner": "gongzzang-platform",
  "status": "active",
  "npm": {
    "manager": "pnpm",
    "audit_command": "pnpm audit",
    "required_overrides": {
      "brace-expansion": "5.0.6",
      "postcss": "8.5.15",
      "vite": "6.4.2"
    }
  },
  "rust": {
    "sca": "cargo-deny",
    "config": "deny.toml",
    "command": "cargo deny check"
  },
  "secret_scanning": {
    "tool": "gitleaks",
    "config": ".gitleaks.toml",
    "ci_action": "gitleaks/gitleaks-action",
    "pre_commit_command": "gitleaks protect --staged --redact -v"
  },
  "ci_gate": {
    "required": true,
    "workflow": ".github/workflows/ci.yml",
    "jobs": [
      {
        "id": "cargo-deny",
        "name": "cargo-deny",
        "command": "cargo deny check"
      },
      {
        "id": "secret-scan",
        "name": "Secret scan (gitleaks)",
        "action": "gitleaks/gitleaks-action"
      }
    ],
    "per_pr_guards": [
      "scripts/lefthook/catalog-m1-boundary.sh",
      "scripts/lefthook/migration-version-prefixes.sh"
    ]
  },
  "removed_pre_launch": {
    "note": "Pre-launch provenance, SBOM-attestation, and production deploy-admission ceremony was removed. See ADR-0044.",
    "adr": "docs/adr/0044-bazel-transition-reconciliation.md",
    "no_longer_exist": [
      "ci job supply-chain-provenance",
      "actions/attest provenance/SBOM attestation steps",
      "cosign release signing",
      ".github/workflows/production-deploy-admission.yml",
      "scripts/ci/verify-production-deploy-candidate",
      "scripts/ci/check-production-edge-admission"
    ]
  }
}
