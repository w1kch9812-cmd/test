        "rejection_status": 429,
        "problem_type": "map/too-many-public-marker-requests"
      },
      "cache_policy": {
        "server_cache": "redis",
        "ttl_seconds": 30,
        "cache_key_fields": ["filter_hash"]
      },
      "single_flight_policy": {
        "required": true,
        "lock_seconds": 5,
        "wait_attempts": 10,
        "wait_milliseconds": 50
      },
      "data_exposure_policy": {
        "exposure_class": "public_derived",
        "client_confidentiality_claim": "none",
        "raw_record_access": "forbidden",
        "bulk_export": "forbidden",
        "allowed_data_classes": ["aggregate_count"],
        "forbidden_data_classes": [
          "raw_listing_detail",
          "private_listing",
          "business_verified_listing_detail",
          "contact_data",
          "raw_platform_core_catalog",
          "bulk_listing_export"
        ]
      }
    },
    {
      "id": "gongzzang.public_map.listing_marker_filter",
      "description": "Anonymous browser registration of normalized listing marker filters.",
      "owner": "gongzzang",
      "exposure": "public_anonymous",
      "proxy_path_kind": "exact",
      "proxy_path_source": "API.proxy.listingMarkerFilters",
      "proxy_path": "/api/proxy/map/v1/marker-filters/listing",
      "backend_route": "/map/v1/marker-filters/listing",
      "methods": ["POST"],
      "auth_policy": {
        "method": "anonymous_public",
        "session_required": false
      },
      "rate_policy": {
        "key_prefix": "public-map:listing-marker-filter",
        "limit": 60,
        "window_seconds": 60,
        "rejection_status": 429,
        "problem_type": "map/too-many-public-marker-requests"
      },
      "filter_policy": {
        "normalized_hash_required": true,
        "idempotent_upsert_required": true
      },
      "data_exposure_policy": {
        "exposure_class": "public_derived",
        "client_confidentiality_claim": "none",
        "raw_record_access": "forbidden",
