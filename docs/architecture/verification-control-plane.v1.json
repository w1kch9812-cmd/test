      "exit_target": "//:verify_pr",
      "sunset": "2026-07-31"
    },
    {
      "id": "transition-walking-skeleton-build",
      "pattern": "\\bcargo\\s+build\\s+--package\\s+api\\s+--release\\b",
      "scope": ".github/workflows/walking-skeleton.yml",
      "owner": "build-platform",
      "reason": "Transition until walking-skeleton release build is a Bazel output.",
      "exit_target": "//:verify_release",
      "sunset": "2026-07-31"
    },
    {
      "id": "transition-hook-biome",
