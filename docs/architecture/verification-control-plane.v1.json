      "scope": "lefthook.yml",
      "owner": "build-platform",
      "reason": "Pre-commit formatter transition until staged-file linting is represented through Bazel.",
      "exit_target": "//:verify_fast",
      "sunset": "2026-07-31"
    },
    {
      "id": "transition-hook-cargo-fmt",
      "pattern": "\\bcargo\\s+fmt\\s+--\\s+\\{staged_files\\}",
      "scope": "lefthook.yml",
      "owner": "build-platform",
      "reason": "Pre-commit formatter transition until Rust formatting is represented through Bazel.",
      "exit_target": "//:verify_fast",
      "sunset": "2026-07-31"
    },
    {
      "id": "transition-hook-markdownlint",
      "pattern": "\\bpnpm\\s+markdownlint-cli2\\b",
      "scope": "lefthook.yml",
      "owner": "build-platform",
      "reason": "Pre-commit markdown lint transition until represented through Bazel.",
      "exit_target": "//:verify_fast",
      "sunset": "2026-07-31"
    },
    {
      "id": "transition-hook-cargo-check",
      "pattern": "\\bcargo\\s+check\\s+--workspace\\s+--all-features\\b",
      "scope": "lefthook.yml",
      "owner": "build-platform",
