# === 외부 공공 API ===
# V-World (https://www.vworld.kr/dev/v4api.do)
VWORLD_API_KEY=your_vworld_key_here
VWORLD_DOMAIN=localhost

# 법제처 (https://open.law.go.kr/LSO/openApi/guideList.do)
KOREAN_LAW_API_KEY=your_law_api_key_here

# 공공데이터포털 (https://data.go.kr)
ODP_SERVICE_KEY=your_data_go_kr_key_here

# NICE 본인인증
NICE_API_KEY=your_nice_key_here
NICE_CLIENT_ID=

# 네이버 지도 (https://www.ncloud.com)
NAVER_MAPS_CLIENT_ID=your_naver_client_id_here
NAVER_MAPS_CLIENT_SECRET=

# === 인증 (Zitadel) ===
ZITADEL_DOMAIN=https://your-instance.zitadel.cloud
ZITADEL_PROJECT_ID=
ZITADEL_API_KEY=
# JWT 검증용 — services/api 가 startup 단계에서 필수.
ZITADEL_ISSUER=https://zitadel.local
ZITADEL_AUDIENCE=client-id-from-zitadel

# === 임베딩 (Gemini, Phase 3+) ===
GEMINI_API_KEY=

# === DB ===
# 로컬 개발용. 운영 비밀번호는 절대 여기에 두지 않아요.
# 비밀번호는 infrastructure/docker/.env(.example)와 동일하게 맞춰요.
DATABASE_URL=postgres://gongzzang:changeme_local_only@localhost:5432/gongzzang
REDIS_URL=redis://localhost:6379

# === 관측성 ===
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=gongzzang-api

# === 환경 ===
NODE_ENV=development
RUST_LOG=info
RUST_BACKTRACE=1
