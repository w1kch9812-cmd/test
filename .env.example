# === 외부 공공 API ===
# V-World (https://www.vworld.kr/dev/v4api.do)
VWORLD_API_KEY=your_vworld_key_here
VWORLD_DOMAIN=localhost

# 법제처 (https://open.law.go.kr/LSO/openApi/guideList.do)
KOREAN_LAW_API_KEY=your_law_api_key_here

# 공공데이터포털 (https://data.go.kr)
ODP_SERVICE_KEY=your_data_go_kr_key_here

# NICE 본인인증
NICE_API_KEY=your_nice_key_here
NICE_CLIENT_ID=

# 네이버 지도 (https://www.ncloud.com)
NAVER_MAPS_CLIENT_ID=your_naver_client_id_here
NAVER_MAPS_CLIENT_SECRET=

# === 인증 (Zitadel) ===
ZITADEL_DOMAIN=https://your-instance.zitadel.cloud
ZITADEL_PROJECT_ID=
ZITADEL_API_KEY=
# JWT 검증용 — services/api 가 startup 단계에서 필수.
ZITADEL_ISSUER=https://zitadel.local
ZITADEL_AUDIENCE=client-id-from-zitadel

# === 임베딩 (Gemini, Phase 3+) ===
GEMINI_API_KEY=

# === DB ===
# 로컬 개발용. 운영 비밀번호는 절대 여기에 두지 않아요.
# 비밀번호는 infrastructure/docker/.env(.example)와 동일하게 맞춰요.
DATABASE_URL=postgres://gongzzang:changeme_local_only@localhost:5432/gongzzang
REDIS_URL=redis://localhost:6379

# === 관측성 ===
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=gongzzang-api

# === 환경 ===
NODE_ENV=development
RUST_LOG=info
RUST_BACKTRACE=1

# === SP9 ETL 환경 (ADR 0029) ===
# `ETL_ENVIRONMENT` 명시 필수 — 미설정 시 fail-fast. 각 env 별 secret namespace 격리.
# local 머신은 보통 'local' — production R2 credential 자동 활성 차단.
ETL_ENVIRONMENT=local

# === SP9 R2 credentials — environment namespace 격리 (ADR 0029) ===
# local smoke 시 *비워두기* = R2 비활성 (local-only mode). 실 R2 로 smoke 하려면 set.
# 실수로 production credential 박제해도 ETL_ENVIRONMENT=local 이면 R2 활성 X.
R2_LOCAL_ACCOUNT_ID=
R2_LOCAL_ACCESS_KEY=
R2_LOCAL_SECRET_KEY=
R2_LOCAL_BUCKET=

# staging (별도 R2 bucket — production-like 검증).
R2_STAGING_ACCOUNT_ID=
R2_STAGING_ACCESS_KEY=
R2_STAGING_SECRET_KEY=
R2_STAGING_BUCKET=

# production (보통 .env 에 *박제 안 함* — GitHub Actions secrets 통해 inject).
# 만약 박제 시 ETL_ENVIRONMENT=production 명시 필요.
R2_PRODUCTION_ACCOUNT_ID=
R2_PRODUCTION_ACCESS_KEY=
R2_PRODUCTION_SECRET_KEY=
R2_PRODUCTION_BUCKET=

# === DEPRECATED (ADR 0030 에서 제거) — backward-compat 1 sprint ===
# 기존 R2_* (namespace 없음). 활성 시 *경고 로그* 출력. 신규 setup 은 R2_<ENV>_* 권장.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY=
# R2_SECRET_KEY=
# R2_BUCKET=
